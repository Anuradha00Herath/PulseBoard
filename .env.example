# Copy this file to .env and adjust as needed.
# docker-compose.yml currently hardcodes most of these directly for Sprint 0 simplicity;
# this file documents what will move to real env-based config starting Sprint 1.

# --- Postgres ---
POSTGRES_USER=pulseboard
POSTGRES_PASSWORD=pulseboard
POSTGRES_DB=pulseboard
DATABASE_URL=postgres://pulseboard:pulseboard@postgres:5432/pulseboard

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- Kafka ---
KAFKA_BROKER=kafka:9092

# --- Auth (added Sprint 1) ---
JWT_SECRET=change-me-in-sprint-1

# --- Service ports ---
AUTH_SERVICE_PORT=4001
INGESTION_SERVICE_PORT=4002
WS_GATEWAY_PORT=4003
